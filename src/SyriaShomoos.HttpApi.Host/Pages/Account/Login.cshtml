@page
@using Microsoft.AspNetCore.Mvc.Localization
@using Volo.Abp.Account.Localization
@model Volo.Abp.Account.Web.Pages.Account.LoginModel
@inject IHtmlLocalizer<AccountResource> L

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Login</title>

    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        * {
            font-family: 'Montserrat', sans-serif;
        }

        .custom-login-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: #F3FFDC;
        }

        .login-card {
            display: flex;
            width: 1000px;
            max-width: 95%;
            height: 550px;
            background: white;
            box-shadow: 0 15px 40px rgba(0,0,0,0.08);
            overflow: hidden;
        }

        .card-left {
            flex: 1;
            position: relative;
        }

        .shape-overlay {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .left-content {
            position: absolute;
            top: 50%;
            left: 80px;
            transform: translateY(-50%);
            color: white;
            text-align: center;
        }

        .windows-icon {
            width: 48px;
            margin-bottom: 20px;
        }

        .card-right {
            flex: 1;
            padding: 4rem 3rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .login-title {
            text-align: center;
            font-size: 24px;
            margin-bottom: 24px;
            color: #3F4F2C;
        }

        .custom-input {
            width: 100%;
            padding: 10px;
            border: 1px solid #ccc;
            margin-bottom: 15px;
        }

        .btn-login {
            padding: 12px;
            background: #3F4F2C;
            color: white;
            border: none;
            cursor: pointer;
        }
    </style>
</head>

<body>

    <div class="custom-login-container">

        <div class="login-card">

            <!-- LEFT -->
            <div class="card-left">
                <img src="~/images/login/login2bg.svg" class="shape-overlay" />

                <div class="left-content">
                    <img src="~/images/login/shield-check.svg" class="windows-icon" />
                    <h2>SecureSyria System</h2>
                </div>
            </div>

            <!-- RIGHT -->
            <div class="card-right">

                <h2 class="login-title">@L["Login"]</h2>

                @if (Model.EnableLocalLogin)
                {
                    <form method="post">

                        <input asp-for="ReturnUrl" type="hidden" />

                        <input asp-for="LoginInput.UserNameOrEmailAddress"
                               placeholder="Email"
                               class="custom-input" />

                        <input asp-for="LoginInput.Password"
                               type="password"
                               placeholder="Password"
                               class="custom-input"
                               id="passwordInput" />

                        <button type="submit" class="btn-login">
                            @L["Login"]
                        </button>
                    </form>
                }

            </div>
        </div>
    </div>

    <script>
        // toggle password
        function togglePassword() {
            var input = document.getElementById("passwordInput");
            input.type = input.type === "password" ? "text" : "password";
        }
    </script>

</body>
</html>